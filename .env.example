# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# OpenAI Configuration (for later)
OPENAI_API_KEY=your_openai_api_key

# Google API Configuration (for later)
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback

# Google Chat Webhook (for later)
GOOGLE_CHAT_WEBHOOK_URL=your_webhook_url

# LangSmith Configuration (for later)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=ai-career-notifier
